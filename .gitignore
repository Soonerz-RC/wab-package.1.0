# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Secrets — API keys, etc. Never commit.
.env
.env.*
!.env.example

# Node (forbidden per CLAUDE.md §5 but ignore preemptively)
node_modules/

# Netlify build artifact — site/data/ is created at deploy time only
# (see netlify.toml). The canonical data/ lives at the repo root.
site/data/

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Excel lock files (created when a file is open in Excel)
~$*.xlsx
~$*.xls

# Claude plugin tooling artifacts
site/CLAUDE.md

# Map-build cache (Census TIGER shapefile download, regeneratable)
scripts/.cache/
